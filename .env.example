# ---------------------------------------------------------------------------
# Copy to .env and fill in.  All values have sensible defaults except the token.
# ---------------------------------------------------------------------------

# Whissle gateway token (wh_...). Required for the STT + audio-visual step (02).
# The gateway requires:  Authorization: Bearer wh_...
# Create one at https://lulu.whissle.ai/access
WHISSLE_API_TOKEN=

# Whissle gateway base URL. Default is the local docker on :9000.
# (Use https://api.whissle.ai to hit the cloud gateway instead.)
WHISSLE_GATEWAY_URL=http://localhost:9000

# Per-segment metadata tags the ASR model should emit, and diarization on/off.
WHISSLE_METADATA_TAGS=emotion,intent,age,gender
WHISSLE_DIARIZATION=1

# Frames per second sampled for the audio-visual lane (gateway side).
VISUAL_SAMPLE_FPS=5

# Optional Claude semantic visual lane (scene/activity/entities). Off by default.
# This is enabled on the GATEWAY (it needs ANTHROPIC_API_KEY in the gateway
# container); here we just ask /video/analyze to run it via semantic=true.
VISUAL_SEMANTIC_LANE=0
ANTHROPIC_API_KEY=

# ---- Paths ----------------------------------------------------------------
# Raw dataset root (contains Clips/, Transcription/, Annotation/, README.txt)
DECEPTION_DATASET_DIR=/Users/karan/Downloads/Real-life_Deception_Detection_2016
